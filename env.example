# -----------------------------------------------------------------------------
# FIREBASE CONFIGURATION (Client Side)
# -----------------------------------------------------------------------------
# Estas variáveis precisam do prefixo NEXT_PUBLIC_ para serem lidas pelo navegador.

NEXT_PUBLIC_API_KEY=sua_api_key_aqui
NEXT_PUBLIC_AUTH_DOMAIN=seu-app.firebaseapp.com
NEXT_PUBLIC_PROJECT_ID=seu-projeto-id
NEXT_PUBLIC_STORAGE_BUCKET=seu-app.appspot.com
NEXT_PUBLIC_MESSAGING_SENDER_ID=1234567890
NEXT_PUBLIC_APP_ID=1:1234567890:web:abc12345
NEXT_PUBLIC_MEASUREMENT_ID=G-ABCDEFGH
NEXT_PUBLIC_FIRESTORE_DATABASE_ID=(default)

# -----------------------------------------------------------------------------
# SERVER SIDE ONLY (Exemplo de variáveis privadas)
# -----------------------------------------------------------------------------
# Estas NÃO têm o prefixo NEXT_PUBLIC_ e só funcionam no Node.js/API Routes.

FIREBASE_SERVICE_ACCOUNT_KEY=
DATABASE_URL=
STRIPE_SECRET_KEY=